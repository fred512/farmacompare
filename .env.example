# Google Places API - para buscar farmácias próximas
# Obter em: https://console.cloud.google.com/apis/library/places-backend.googleapis.com
GOOGLE_PLACES_API_KEY=sua_chave_aqui

# Anthropic API - para comparação de preços via IA
# Obter em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sua_chave_aqui

# PharmaDB API (opcional) - dados oficiais ANVISA/CMED
# Obter em: https://pharmadb.com.br
PHARMADB_API_KEY=sua_chave_aqui
